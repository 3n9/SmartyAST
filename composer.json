{
    "name": "3n9/smarty-ast",
    "type": "library",
    "description": "Smarty template AST parser with diagnostics and position tracking",
    "license": "proprietary",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^13"
    },
    "autoload": {
        "psr-4": {
            "SmartyAst\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SmartyAst\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml"
    }
}
